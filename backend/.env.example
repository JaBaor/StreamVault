PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_NAME=streaming_db
DB_USER=root
DB_PASSWORD=your_mysql_password

JWT_SECRET=change_this_to_a_long_random_string

ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: single connection URL (mysql://user:pass@host:port/database)
# Example:
# DATABASE_URL=mysql://root:password@host:3306/streaming_db
